                <mxCell id="xcut" value=" " style="swimlane;startSize=30;html=1;fillColor=#fbfbfb;strokeColor=#888888;fontStyle=1;fontColor=#333333;verticalAlign=top;dashed=1;" parent="1" vertex="1">
