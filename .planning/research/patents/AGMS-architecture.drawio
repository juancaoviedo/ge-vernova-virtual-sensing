                <mxCell id="xsim" value="Simulate-before-commit — a law&#xa;CaCSM promotion (GA) • operation&#xa;loop formation [granted claim 3]&#xa;• ORACS verification simulation.&#xa;Never actuate on an unvalidated plan." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" parent="xcut" vertex="1">
