                </mxCell>
                <mxCell id="xdata" value="Data Management / POV files&#xa;sole interface to the asset DB — no&#xa;module touches raw data. Role-filtered&#xa;views via patterns DB + Learning Engine:&#xa;• viewConstructModule (observe)&#xa;• controlConstructModule (actuate)&#xa;• adminConstructModule (coordinate)&#xa;GridWideEye builds PoV frames." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" parent="xcut" vertex="1">
                    <mxGeometry x="20" y="760" width="340" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="xfed" value="Federation &amp; autonomy spectrum (oft)&#xa;ioc.cc  independent, supports central cmd&#xa;ioc.sc  fully autonomous cell&#xa;ioc.coc  member of cooperating neighbors&#xa;ioc.fm  sub-federation member&#xa;Cells merge / federate under a scout-master." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3eef7;strokeColor=#9673a6;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" parent="xcut" vertex="1">
                    <mxGeometry x="20" y="1280" width="340" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="xsec" value="Security in the protocol&#xa;every inter-module message carries a&#xa;ga-authenticationkey, validated by a&#xa;ga-GateKeeper before any state machine&#xa;activates or data is released.&#xa;gAVA standardizes the message schema&#xa;so all modules speak one language." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" parent="xcut" vertex="1">
                    <mxGeometry x="20" y="270" width="340" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="4DyDUN3vrFLzL9egiClx-17" value="POV files are interesting way of managing data access by role. But I wonder if the &quot;schema&quot; changes as the system evolves (like new devices enter the system). I that drift managed by updateing the POV?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;" parent="xcut" vertex="1">
                    <mxGeometry x="20" y="930" width="160" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="4DyDUN3vrFLzL9egiClx-19" value="A cell can hand off authority to a neighbour. This is managed by the Federated Edge Transaction Manager. Is this transfer cell 1 notifies transfer to cloud, cloud terminates cell 1, cloud spawn cell 2 with same config as 1? Or is it really a local cell 1 transfer itself to cell 2 over local network without cloud involvement?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;" parent="xcut" vertex="1">
