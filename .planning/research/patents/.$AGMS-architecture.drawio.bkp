        </mxCell>
        <mxCell id="4DyDUN3vrFLzL9egiClx-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;" value="Does the virtual sensing module dictate to add more measuring points? Or should always work with what is already available?" vertex="1">
