        <mxCell id="4DyDUN3vrFLzL9egiClx-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;" value="Alerts come only from measurements? Or can they come from &quot;stimated&quot; states from the virtual sensing module?" vertex="1">
