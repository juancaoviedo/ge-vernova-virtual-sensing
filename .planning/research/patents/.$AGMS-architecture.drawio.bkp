        </mxCell>
        <mxCell id="4DyDUN3vrFLzL9egiClx-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;" value="Virtual sensing module uses the sim. eng. to compute global state? Or the sim. eng. only computes effects of the CaCSM actions?" vertex="1">
