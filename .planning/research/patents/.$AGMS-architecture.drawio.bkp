        </mxCell>
        <mxCell id="4DyDUN3vrFLzL9egiClx-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;" value="Pattern extraction from DB? so the pattern recognition can work?" vertex="1">
